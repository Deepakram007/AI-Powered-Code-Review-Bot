# Server configuration
PORT=3000
NODE_ENV=development

# Database configuration (PostgreSQL)
# For local Docker: postgresql://postgres:postgres@localhost:5432/review_bot?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/review_bot?schema=public

# GitHub App configuration
GITHUB_APP_ID=123456
# GITHUB_PRIVATE_KEY should be base64-encoded to prevent multiline formatting issues in environment setup, 
# or can be the raw PEM key block if supported by the deployment platform.
GITHUB_PRIVATE_KEY=your-base64-encoded-private-key
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# AI configuration (OpenAI or compatible API)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Slack Integration configuration
SLACK_WEBHOOK_URL=your-slack-webhook-url
